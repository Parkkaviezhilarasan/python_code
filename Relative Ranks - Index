class Solution(object):
    def findRelativeRanks(self, score):
        indexed = sorted(enumerate(score), key=lambda x: x[1], reverse=True)   
        res = [""] * len(score)        
        for rank, (idx, val) in enumerate(indexed):            
            if rank == 0:
                res[idx] = "Gold Medal"
            elif rank == 1:
                res[idx] = "Silver Medal"
            elif rank == 2:
                res[idx] = "Bronze Medal"
            else:
                res[idx] = str(rank + 1)
        
        return res
